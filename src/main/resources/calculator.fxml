<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CalculatorController">

    <padding>
        <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Enter two numbers:" />

    <TextField fx:id="number1Field" promptText="Number 1" />
    <TextField fx:id="number2Field" promptText="Number 2" />

    <Button onAction="#onCalculateClick" text="Calculate Save">
      <VBox.margin>
         <Insets bottom="3.0" top="10.0" />
      </VBox.margin></Button>

    <Label fx:id="resultLabel" wrapText="true" maxWidth="300.0">
      <VBox.margin>
         <Insets />
      </VBox.margin></Label>

</VBox>
